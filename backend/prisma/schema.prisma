// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model usuarios {
  id_user     Int      @id @default(autoincrement())
  nome        String
  cpf         String
  foto_perfil String?
  email       String
  senha       String

  posts       posts[]
  comentarios comentarios[]
  curtidas    curtidas[]
}

model projetos {
  id_proj       Int      @id @default(autoincrement())
  nome          String
  conteudo      String
  data_inicial  DateTime
  data_final    DateTime
  data_cadastro DateTime

  posts     posts[]
  curtidas  curtidas[]
}

model posts {
  id_post   Int      @id @default(autoincrement())
  conteudo  String
  date_hora DateTime

  id_user Int
  id_proj Int

  usuario usuarios @relation(fields: [id_user], references: [id_user])
  projeto projetos @relation(fields: [id_proj], references: [id_proj])

  comentarios comentarios[]
  curtidas    curtidas[]
}

model comentarios {
  id_post   Int
  id_user   Int
  date_hora DateTime
  comentario String

  post    posts    @relation(fields: [id_post], references: [id_post])
  usuario usuarios @relation(fields: [id_user], references: [id_user])

  @@id([id_post, id_user, date_hora])
}

model curtidas {
  id_post Int
  id_user Int
  id_proj Int

  post    posts    @relation(fields: [id_post], references: [id_post])
  usuario usuarios @relation(fields: [id_user], references: [id_user])
  projeto projetos @relation(fields: [id_proj], references: [id_proj])

  @@id([id_post, id_user])
}